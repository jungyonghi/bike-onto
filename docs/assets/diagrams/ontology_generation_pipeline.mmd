%% Bike Onto / OBYBK ontology generation pipeline
flowchart LR
    subgraph A[Conceptual anchor]
        BMO[Business Model Ontology paper\nOsterwalder]
        P4[4 pillars\nProduct / Customer Interface\nInfrastructure / Financial]
        E9[9 elements\nValue / Customer / Channel\nRelationship / Capability\nConfiguration / Partnership\nRevenue / Cost]
        BMO --> P4
        BMO --> E9
    end

    subgraph B[Formalization blueprint]
        BP[OWL 2 DL-style blueprint]
        TBOX[TBox classes\nBusinessModelDescription\nPillar / Element / SubElement]
        PROPS[Object properties\nvalueForCustomer\nsupportsValueProposition\nusesDataset / hasEvidence]
        CODE[Code lists + constraints\nvalue level / lifecycle\nSHACL roadmap]
        BP --> TBOX
        BP --> PROPS
        BP --> CODE
    end

    subgraph C[Upper ontology seed]
        GEN[generate_codex_upper_ontology_seed.py]
        CAT[12 general categories\nactor / org / place / time\nasset / event / capability\ndocument / policy / value\nrisk / channel]
        FAC[7 facets\nIdentity / Boundary / Role\nState / Relation / Lifecycle\nEvidence]
        CAND[1,000 candidate records\nrelevance / reusability\ncentrality / clarity\ncomposability]
        PROMO[Promotion records\ncore_upper\ngeneral_reference]
        GEN --> CAT
        GEN --> FAC
        CAT --> CAND
        FAC --> CAND
        CAND --> PROMO
    end

    subgraph D[Domain binding]
        ART[Domain artifacts\ntables / docs / exports]
        MAN[domain_manifest.json]
        QP[QP questions\nexecutable data queries]
        QO[QO questions\nmetric / relation / provenance\nreview gate]
        SLICE[Domain ontology slice\nentities / relations / evidence roles]
        ART --> MAN
        MAN --> QP
        MAN --> QO
        PROMO --> SLICE
        QP --> SLICE
        QO --> SLICE
    end

    subgraph E[Runtime projection]
        RAG[RAG answer payload]
        DEC[Inspection decomposition\nclaim / evidence / entity / relation]
        REV[Answerability + review policy]
        VGP[VisualGraphPayload]
        OUT[Visual Inspector\nEvaluation Overview\nObsidian Wiki]
        SLICE --> RAG
        RAG --> REV
        REV --> DEC
        DEC --> VGP
        VGP --> OUT
    end

    BMO --> BP
    BP --> GEN
